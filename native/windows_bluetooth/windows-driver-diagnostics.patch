@@ -186,24 +186,28 @@ Return Value:
     NTSTATUS status;
     PBTHECHOSAMPLE_SERVER_CONTEXT devCtx = GetServerDeviceContext(Device);
 
+    devCtx->InitializationStage = SPLATPLOST_INIT_STAGE_LOCAL_INFO;
     status = BthEchoSharedRetrieveLocalInfo(&devCtx->Header);
     if (!NT_SUCCESS(status))
     {
-        goto exit;
+        goto failed;
     }
 
+    devCtx->InitializationStage = SPLATPLOST_INIT_STAGE_PSM;
     status = BthEchoSrvRegisterPSM(devCtx);
     if (!NT_SUCCESS(status))
     {
-        goto exit;
+        goto failed;
     }
 
+    devCtx->InitializationStage = SPLATPLOST_INIT_STAGE_L2CAP_SERVER;
     status = BthEchoSrvRegisterL2CAPServer(devCtx);
     if (!NT_SUCCESS(status))
     {
-        goto exit;
+        goto failed;
     }
 
+    devCtx->InitializationStage = SPLATPLOST_INIT_STAGE_SDP;
     status = BthEchoSrvPublishSdpRecord(
         devCtx,
         g_SwitchSdpRecord,
@@ -211,11 +215,16 @@ Return Value:
         );
     if (!NT_SUCCESS(status))
     {
-        goto exit;
+        goto failed;
     }
-    
-exit:
-    return status;    
+
+    devCtx->InitializationStage = SPLATPLOST_INIT_STAGE_READY;
+    devCtx->InitializationStatus = STATUS_SUCCESS;
+    return STATUS_SUCCESS;
+
+failed:
+    devCtx->InitializationStatus = status;
+    return STATUS_SUCCESS;
 }    
 
 VOID
