@@ -2,12 +2,17 @@
 
 #define SPLATPLOST_CONTROL_PSM   0x0011
 #define SPLATPLOST_INTERRUPT_PSM 0x0013
+#define SPLATPLOST_INIT_STAGE_LOCAL_INFO       1
+#define SPLATPLOST_INIT_STAGE_PSM              2
+#define SPLATPLOST_INIT_STAGE_L2CAP_SERVER     3
+#define SPLATPLOST_INIT_STAGE_SDP              4
+#define SPLATPLOST_INIT_STAGE_READY            5
 #define IOCTL_SPLATPLOST_GET_STATUS \
     CTL_CODE(FILE_DEVICE_UNKNOWN, 0x800, METHOD_BUFFERED, FILE_ANY_ACCESS)
 
 typedef struct _SPLATPLOST_STATUS {
     ULONG ConnectedChannels;
-    ULONG Reserved;
+    NTSTATUS InitializationStatus;
     BTH_ADDR LocalAddress;
 } SPLATPLOST_STATUS, *PSPLATPLOST_STATUS;
 
diff --git a/bluetooth/bthecho/bthsrv/sys/device.c b/bluetooth/bthecho/bthsrv/sys/device.c
