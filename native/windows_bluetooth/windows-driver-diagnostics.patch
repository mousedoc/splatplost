diff --git a/bluetooth/bthecho/bthsrv/sys/bridge.h b/bluetooth/bthecho/bthsrv/sys/bridge.h
index 8a3d24e..1b09a8b 100644
--- a/bluetooth/bthecho/bthsrv/sys/bridge.h
