+BthEchoSrvStopPairingRegistration(
+    _In_ PBTHECHOSAMPLE_SERVER_CONTEXT DevCtx
+    )
+{
+    PAGED_CODE();
+
+    WdfSpinLockAcquire(DevCtx->PairingStateLock);
+    DevCtx->RegistrationStopping = TRUE;
+    DevCtx->PairingGeneration++;
+    WdfSpinLockRelease(DevCtx->PairingStateLock);
+
+    // Stop callbacks first, then wait for the one reusable worker to finish.
+    WdfWaitLockAcquire(DevCtx->RegistrationLock, NULL);
+    BthEchoSrvUnregisterL2CAPServer(DevCtx);
+    WdfWaitLockRelease(DevCtx->RegistrationLock);
+    WdfWorkItemFlush(DevCtx->PairingWorkItem);
+
