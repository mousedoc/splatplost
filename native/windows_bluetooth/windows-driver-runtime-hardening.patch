+_IRQL_requires_max_(DISPATCH_LEVEL)
+static USHORT
+BthEchoSrvReserveConnection(
+    _In_ PBTHECHOSAMPLE_SERVER_CONTEXT DevCtx,
+    _In_ PBTHECHO_CONNECTION Connection,
+    _In_ BTH_ADDR BtAddress,
+    _In_ USHORT Psm
+    )
+{
+    USHORT response = CONNECT_RSP_RESULT_SECURITY_BLOCK;
+    PLIST_ENTRY entry;
+
+    Connection->RemoteAddress = BtAddress;
+    Connection->Psm = Psm;
+
+    if (Psm != SPLATPLOST_CONTROL_PSM &&
+        Psm != SPLATPLOST_INTERRUPT_PSM)
+    {
+        return CONNECT_RSP_RESULT_PSM_NEG;
+    }
+
+    WdfSpinLockAcquire(DevCtx->PairingStateLock);
+    if (DevCtx->RegistrationStopping ||
+        DevCtx->SurpriseRemoved ||
+        DevCtx->TargetTransitioning ||
+        !DevCtx->DeviceServersReady ||
+        DevCtx->DeviceServerAddress != BtAddress ||
+        (DevCtx->ProvenRemoteAddress != BTH_ADDR_NULL &&
+         DevCtx->ProvenRemoteAddress != BtAddress))
+    {
+        WdfSpinLockRelease(DevCtx->PairingStateLock);
+        return response;
+    }
+
+    WdfSpinLockAcquire(DevCtx->ConnectionListLock);
+    if (DevCtx->BridgeRemoteAddress != BTH_ADDR_NULL &&
+        DevCtx->BridgeRemoteAddress != BtAddress)
+    {
+        goto unlock;
+    }
+
+    for (entry = DevCtx->ConnectionList.Flink;
+         entry != &DevCtx->ConnectionList;
+         entry = entry->Flink)
+    {
+        PBTHECHO_CONNECTION existing = CONTAINING_RECORD(
+            entry,
+            BTHECHO_CONNECTION,
+            ConnectionListEntry
+            );
+
+        if (existing->RemoteAddress != BtAddress)
+        {
+            goto unlock;
+        }
+        if (existing->Psm == Psm)
+        {
+            response = CONNECT_RSP_RESULT_NO_RESOURCES;
+            goto unlock;
+        }
+    }
+
+    InsertTailList(&DevCtx->ConnectionList, &Connection->ConnectionListEntry);
+    Connection->InConnectionList = TRUE;
+    response = CONNECT_RSP_RESULT_SUCCESS;
+
+unlock:
+    WdfSpinLockRelease(DevCtx->ConnectionListLock);
+    WdfSpinLockRelease(DevCtx->PairingStateLock);
+    return response;
+}
