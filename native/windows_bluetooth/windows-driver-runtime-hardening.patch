+VOID
+SplatplostEvtDeviceFileCreate(
+    _In_ WDFDEVICE Device,
+    _In_ WDFREQUEST Request,
+    _In_ WDFFILEOBJECT FileObject
+    )
+{
+    ACCESS_MASK desiredAccess = 0;
+    BOOLEAN controllerAccess;
+    NTSTATUS status = STATUS_SUCCESS;
+    WDF_REQUEST_PARAMETERS parameters;
+    PSPLATPLOST_FILE_CONTEXT fileCtx =
+        GetSplatplostFileContext(FileObject);
+    PBTHECHOSAMPLE_SERVER_CONTEXT devCtx =
+        GetServerDeviceContext(Device);
+
+    WDF_REQUEST_PARAMETERS_INIT(&parameters);
+    WdfRequestGetParameters(Request, &parameters);
+    if (parameters.Parameters.Create.SecurityContext != NULL)
+    {
+        desiredAccess =
+            parameters.Parameters.Create.SecurityContext->DesiredAccess;
+    }
+
+    controllerAccess =
+        (desiredAccess &
+         (FILE_READ_DATA | FILE_WRITE_DATA | FILE_APPEND_DATA |
+          GENERIC_READ | GENERIC_WRITE)) != 0;
+    fileCtx->OwnsController = FALSE;
+
+    if (controllerAccess)
+    {
+        WdfSpinLockAcquire(devCtx->ConnectionListLock);
+        if (devCtx->ControllerFileObject != NULL ||
+            devCtx->ControllerCleanupInProgress)
+        {
+            status = STATUS_SHARING_VIOLATION;
+        }
+        else
+        {
+            devCtx->ControllerFileObject = FileObject;
+            fileCtx->OwnsController = TRUE;
+        }
+        WdfSpinLockRelease(devCtx->ConnectionListLock);
+    }
+
+    WdfRequestComplete(Request, status);
+}
+
+VOID
+SplatplostEvtFileCleanup(
+    _In_ WDFFILEOBJECT FileObject
+    )
+{
+    WDFREQUEST request;
+    NTSTATUS status;
+    PSPLATPLOST_FILE_CONTEXT fileCtx =
+        GetSplatplostFileContext(FileObject);
+    PBTHECHOSAMPLE_SERVER_CONTEXT devCtx =
+        GetServerDeviceContext(WdfFileObjectGetDevice(FileObject));
+
+    if (!fileCtx->OwnsController)
+    {
+        return;
+    }
+
+    WdfSpinLockAcquire(devCtx->ConnectionListLock);
+    if (devCtx->ControllerFileObject == FileObject)
+    {
+        devCtx->ControllerFileObject = NULL;
+        devCtx->ControllerCleanupInProgress = TRUE;
+        SplatplostResetPacketFifoLocked(devCtx);
+    }
+    fileCtx->OwnsController = FALSE;
+    WdfSpinLockRelease(devCtx->ConnectionListLock);
+
+    // EvtFileCleanup can run while manual-queue requests still exist. Remove
+    // only this controller's reads before admitting a replacement owner.
+    for (;;)
+    {
+        status = WdfIoQueueRetrieveRequestByFileObject(
+            devCtx->PendingReads,
+            FileObject,
+            &request
+            );
+        if (!NT_SUCCESS(status))
+        {
+            if (status != STATUS_NO_MORE_ENTRIES)
+            {
+                TraceEvents(
+                    TRACE_LEVEL_ERROR,
+                    DBG_PNP,
+                    "Unable to drain controller read queue, status = %!STATUS!\n",
+                    status
+                    );
+            }
+            break;
+        }
+        WdfRequestComplete(request, STATUS_CANCELLED);
+    }
+
+    WdfSpinLockAcquire(devCtx->ConnectionListLock);
+    devCtx->ControllerCleanupInProgress = FALSE;
+    WdfSpinLockRelease(devCtx->ConnectionListLock);
+}
