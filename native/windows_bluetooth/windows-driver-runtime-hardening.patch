+#define SPLATPLOST_CLEANUP_CONNECTION_CAPACITY 4
+
+_IRQL_requires_max_(DISPATCH_LEVEL)
+static VOID
+SplatplostReferenceConnectionForCleanupLocked(
+    _In_ WDFOBJECT ConnectionObject,
+    _Inout_updates_(ConnectionObjectCapacity)
+        WDFOBJECT *ConnectionObjects,
+    _In_ ULONG ConnectionObjectCapacity,
+    _Inout_ PULONG ConnectionObjectCount
+    )
+{
+    PBTHECHO_CONNECTION connection;
+    ULONG index;
+
+    if (ConnectionObject == NULL)
+    {
+        return;
+    }
+
+    for (index = 0; index < *ConnectionObjectCount; index++)
+    {
+        if (ConnectionObjects[index] == ConnectionObject)
+        {
+            return;
+        }
+    }
+
+    connection = GetConnectionObjectContext(ConnectionObject);
+    connection->BridgeReaderReady = FALSE;
+    if (connection->TeardownRequested ||
+        InterlockedCompareExchange(
+            &connection->DeleteRequested,
+            0,
+            0) != 0)
+    {
+        return;
+    }
+
+    // Reservation permits at most one connection for each of the two PSMs.
+    // Two more slots cover objects removed from the list but not yet detached
+    // from the published bridge pointers by a concurrent disconnect callback.
+    NT_ASSERT(*ConnectionObjectCount < ConnectionObjectCapacity);
+    if (*ConnectionObjectCount >= ConnectionObjectCapacity)
+    {
+        return;
+    }
+
+    WdfObjectReference(ConnectionObject);
+    connection->TeardownRequested = TRUE;
+    ConnectionObjects[*ConnectionObjectCount] = ConnectionObject;
+    (*ConnectionObjectCount)++;
+}
