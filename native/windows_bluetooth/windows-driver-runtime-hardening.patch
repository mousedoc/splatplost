+_IRQL_requires_max_(DISPATCH_LEVEL)
+VOID
+BthEchoSrvQueueProvenAddress(
+    _In_ PBTHECHOSAMPLE_SERVER_CONTEXT DevCtx,
+    _In_ BTH_ADDR BtAddress
+    )
+{
+    if (!BthEchoSrvIsValidRemoteAddress(BtAddress))
+    {
+        return;
+    }
+
+    WdfSpinLockAcquire(DevCtx->PairingStateLock);
+    if (!DevCtx->RegistrationStopping &&
+        !DevCtx->SurpriseRemoved &&
+        !DevCtx->TargetTransitioning &&
+        DevCtx->DeviceServersReady &&
+        DevCtx->DeviceServerAddress == BtAddress &&
+        (DevCtx->ProvenRemoteAddress == BTH_ADDR_NULL ||
+         DevCtx->ProvenRemoteAddress == BtAddress))
+    {
+        DevCtx->ProvenRemoteAddress = BtAddress;
+        if (DevCtx->PersistedRemoteAddress != BtAddress)
+        {
+            DevCtx->PersistenceAddress = BtAddress;
+            DevCtx->PersistenceUpdatePending = TRUE;
+            DevCtx->PairingGeneration++;
+            if (!DevCtx->PairingWorkScheduled)
+            {
+                DevCtx->PairingWorkScheduled = TRUE;
+                // Enqueue before dropping PairingStateLock. Teardown sets its
+                // stop flag under the same lock, so its subsequent Flush
+                // cannot miss a producer that has only published the flag.
+                WdfWorkItemEnqueue(DevCtx->PairingWorkItem);
+            }
+        }
+    }
+    WdfSpinLockRelease(DevCtx->PairingStateLock);
+
+}
