+_IRQL_requires_max_(PASSIVE_LEVEL)
+static VOID
+BthEchoSrvDisconnectTargetConnections(
+    _In_ PBTHECHOSAMPLE_SERVER_CONTEXT DevCtx,
+    _In_ BTH_ADDR BtAddress
+    )
+{
+    WDFOBJECT connectionObjects[2];
+    ULONG connectionCount;
+    ULONG index;
+
+    PAGED_CODE();
+
+    do
+    {
+        PLIST_ENTRY entry;
+
+        connectionCount = 0;
+        WdfSpinLockAcquire(DevCtx->ConnectionListLock);
+        for (entry = DevCtx->ConnectionList.Flink;
+             entry != &DevCtx->ConnectionList &&
+                 connectionCount < RTL_NUMBER_OF(connectionObjects);
+             entry = entry->Flink)
+        {
+            PBTHECHO_CONNECTION connection = CONTAINING_RECORD(
+                entry,
+                BTHECHO_CONNECTION,
+                ConnectionListEntry
+                );
+
+            if (connection->RemoteAddress == BtAddress &&
+                !connection->TeardownRequested)
+            {
+                connection->TeardownRequested = TRUE;
+                connectionObjects[connectionCount] =
+                    WdfObjectContextGetObject(connection);
+                WdfObjectReference(connectionObjects[connectionCount]);
+                connectionCount++;
+            }
+        }
+        WdfSpinLockRelease(DevCtx->ConnectionListLock);
+
+        for (index = 0; index < connectionCount; index++)
+        {
+            BthEchoSrvDisconnectConnection(
+                GetConnectionObjectContext(connectionObjects[index])
+                );
+            WdfObjectDereference(connectionObjects[index]);
+        }
+    } while (connectionCount != 0);
+}
