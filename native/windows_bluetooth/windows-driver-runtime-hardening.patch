+NTSTATUS
+SplatplostBridgeConnectionReady(
+    _In_ PBTHECHOSAMPLE_SERVER_CONTEXT DevCtx,
+    _In_ PBTHECHO_CONNECTION Connection
+    )
+{
+    NTSTATUS status = STATUS_DEVICE_NOT_CONNECTED;
+    BOOLEAN targetProven = FALSE;
+    WDFOBJECT object = WdfObjectContextGetObject(Connection);
+
+    WdfSpinLockAcquire(DevCtx->PairingStateLock);
+    if (DevCtx->RegistrationStopping ||
+        DevCtx->SurpriseRemoved ||
+        DevCtx->TargetTransitioning ||
+        !DevCtx->DeviceServersReady ||
+        DevCtx->DeviceServerAddress != Connection->RemoteAddress ||
+        (DevCtx->ProvenRemoteAddress != BTH_ADDR_NULL &&
+         DevCtx->ProvenRemoteAddress != Connection->RemoteAddress))
+    {
+        WdfSpinLockRelease(DevCtx->PairingStateLock);
+        return status;
+    }
+
+    WdfSpinLockAcquire(DevCtx->ConnectionListLock);
+    if (Connection->InConnectionList &&
+        !Connection->TeardownRequested &&
+        InterlockedCompareExchange(
+            &Connection->DeleteRequested,
+            0,
+            0) == 0 &&
+        DevCtx->BridgeRemoteAddress == Connection->RemoteAddress &&
+        ((Connection->Psm == SPLATPLOST_CONTROL_PSM &&
+          DevCtx->ControlConnection == object) ||
+         (Connection->Psm == SPLATPLOST_INTERRUPT_PSM &&
+          DevCtx->InterruptConnection == object)))
+    {
+        Connection->BridgeReaderReady = TRUE;
+        status = STATUS_SUCCESS;
+        if (DevCtx->ControlConnection != NULL &&
+            DevCtx->InterruptConnection != NULL &&
+            GetConnectionObjectContext(
+                DevCtx->ControlConnection)->BridgeReaderReady &&
+            GetConnectionObjectContext(
+                DevCtx->InterruptConnection)->BridgeReaderReady &&
+            GetConnectionObjectContext(
+                DevCtx->ControlConnection)->RemoteAddress ==
+                    Connection->RemoteAddress &&
+            GetConnectionObjectContext(
+                DevCtx->InterruptConnection)->RemoteAddress ==
+                    Connection->RemoteAddress)
+        {
+            targetProven = TRUE;
+        }
     }
     WdfSpinLockRelease(DevCtx->ConnectionListLock);
+    WdfSpinLockRelease(DevCtx->PairingStateLock);
+
+    if (targetProven)
+    {
+        BthEchoSrvQueueProvenAddress(DevCtx, Connection->RemoteAddress);
+    }
+
+    return status;
 }
 
