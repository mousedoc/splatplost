+_IRQL_requires_max_(PASSIVE_LEVEL)
+NTSTATUS
+BthEchoSrvLoadPersistedAddress(
+    _In_ PBTHECHOSAMPLE_SERVER_CONTEXT DevCtx,
+    _Out_ BTH_ADDR *BtAddress
+    )
+{
+    NTSTATUS status;
+    WDFKEY key = NULL;
+    ULONG valueLength = 0;
+    ULONG valueType = REG_NONE;
+    DECLARE_CONST_UNICODE_STRING(valueName, L"ProvenRemoteAddress");
+
+    PAGED_CODE();
+
+    *BtAddress = BTH_ADDR_NULL;
+    status = WdfDriverOpenParametersRegistryKey(
+        WdfDeviceGetDriver(DevCtx->Header.Device),
+        KEY_QUERY_VALUE,
+        WDF_NO_OBJECT_ATTRIBUTES,
+        &key
+        );
+    if (!NT_SUCCESS(status))
+    {
+        return status;
+    }
+
+    status = WdfRegistryQueryValue(
+        key,
+        &valueName,
+        sizeof(*BtAddress),
+        BtAddress,
+        &valueLength,
+        &valueType
+        );
+    WdfRegistryClose(key);
+
+    if (status == STATUS_OBJECT_NAME_NOT_FOUND ||
+        status == STATUS_OBJECT_PATH_NOT_FOUND)
+    {
+        *BtAddress = BTH_ADDR_NULL;
+        return STATUS_SUCCESS;
+    }
+    if (!NT_SUCCESS(status))
+    {
+        *BtAddress = BTH_ADDR_NULL;
+        return status;
+    }
+    if (valueType != REG_QWORD ||
+        valueLength != sizeof(*BtAddress) ||
+        !BthEchoSrvIsValidRemoteAddress(*BtAddress))
+    {
+        *BtAddress = BTH_ADDR_NULL;
+        return STATUS_DATA_ERROR;
+    }
+
+    return STATUS_SUCCESS;
+}
