+
+    WdfSpinLockAcquire(DevCtx->PairingStateLock);
+    if (!DevCtx->SurpriseRemoved)
+    {
+        DevCtx->ActiveBrbSubmissions++;
+        if (DevCtx->ActiveBrbSubmissions == 1)
+        {
+            KeClearEvent(&DevCtx->BrbRundownEvent);
+        }
+        allowed = TRUE;
+    }
+    WdfSpinLockRelease(DevCtx->PairingStateLock);
+
+    return allowed;
