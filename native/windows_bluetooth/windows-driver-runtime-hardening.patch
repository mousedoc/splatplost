+        {
+            DevCtx->ControlConnection = NULL;
+            DevCtx->InterruptConnection = NULL;
+            DevCtx->BridgeRemoteAddress = BTH_ADDR_NULL;
+            DevCtx->PacketFifoHead = 0;
+            DevCtx->PacketFifoTail = 0;
+            DevCtx->PacketFifoCount = 0;
+            WdfSpinLockRelease(DevCtx->ConnectionListLock);
+            break;
+        }
+
+        entry = DevCtx->ConnectionList.Flink;
+        connection = CONTAINING_RECORD(
+            entry,
+            BTHECHO_CONNECTION,
+            ConnectionListEntry
+            );
+        RemoveEntryList(entry);
+        InitializeListHead(entry);
+        connection->InConnectionList = FALSE;
+        connection->TeardownRequested = TRUE;
+        connectionObject = WdfObjectContextGetObject(connection);
+        WdfObjectReference(connectionObject);
+        WdfSpinLockRelease(DevCtx->ConnectionListLock);
+
+        SplatplostBridgeAbandonConnection(DevCtx, connection);
+        WdfObjectDereference(connectionObject);
+    }
+}
