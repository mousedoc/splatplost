diff --git a/bluetooth/bthecho/bthsrv/sys/bridge.c b/bluetooth/bthecho/bthsrv/sys/bridge.c
new file mode 100644
index 0000000..628c881
--- /dev/null
+++ b/bluetooth/bthecho/bthsrv/sys/bridge.c
@@ -0,0 +1,251 @@
+#include "clisrv.h"
+#include "device.h"
+#include "echo.h"
+#include "bridge.h"
+
+#define SPLATPLOST_MAX_REPORT_SIZE 64
+
+NTSTATUS
+SplatplostBridgeInitialize(
+    _In_ WDFDEVICE Device
+    )
+{
+    NTSTATUS status;
+    WDF_IO_QUEUE_CONFIG queueConfig;
+    WDF_OBJECT_ATTRIBUTES attributes;
+    UNICODE_STRING symbolicLink;
+    PBTHECHOSAMPLE_SERVER_CONTEXT devCtx = GetServerDeviceContext(Device);
+
+    RtlInitUnicodeString(&symbolicLink, L"\\DosDevices\\SplatplostBluetooth");
+    status = WdfDeviceCreateSymbolicLink(Device, &symbolicLink);
+    if (!NT_SUCCESS(status)) {
+        return status;
+    }
+
+    WDF_IO_QUEUE_CONFIG_INIT_DEFAULT_QUEUE(
+        &queueConfig,
+        WdfIoQueueDispatchParallel
+        );
+    queueConfig.EvtIoRead = SplatplostEvtIoRead;
+    queueConfig.EvtIoWrite = SplatplostEvtIoWrite;
+    queueConfig.EvtIoDeviceControl = SplatplostEvtIoDeviceControl;
+
+    status = WdfIoQueueCreate(
+        Device,
+        &queueConfig,
+        WDF_NO_OBJECT_ATTRIBUTES,
+        WDF_NO_HANDLE
+        );
+    if (!NT_SUCCESS(status)) {
+        return status;
+    }
+
+    WDF_IO_QUEUE_CONFIG_INIT(&queueConfig, WdfIoQueueDispatchManual);
+    WDF_OBJECT_ATTRIBUTES_INIT(&attributes);
+    attributes.ParentObject = Device;
+
+    return WdfIoQueueCreate(
+        Device,
+        &queueConfig,
+        &attributes,
+        &devCtx->PendingReads
+        );
+}
+
+VOID
+SplatplostEvtIoRead(
+    _In_ WDFQUEUE Queue,
+    _In_ WDFREQUEST Request,
+    _In_ size_t Length
+    )
+{
+    NTSTATUS status;
+    PBTHECHOSAMPLE_SERVER_CONTEXT devCtx =
+        GetServerDeviceContext(WdfIoQueueGetDevice(Queue));
+
+    if (Length < SPLATPLOST_MAX_REPORT_SIZE) {
+        WdfRequestComplete(Request, STATUS_BUFFER_TOO_SMALL);
+        return;
+    }
+
+    status = WdfRequestForwardToIoQueue(Request, devCtx->PendingReads);
+    if (!NT_SUCCESS(status)) {
+        WdfRequestComplete(Request, status);
+    }
+}
+
+VOID
+SplatplostEvtIoWrite(
+    _In_ WDFQUEUE Queue,
+    _In_ WDFREQUEST Request,
+    _In_ size_t Length
+    )
+{
+    NTSTATUS status;
+    PVOID input = NULL;
+    WDFOBJECT connectionObject = NULL;
+    PBTHECHO_CONNECTION connection = NULL;
+    PBTHECHOSAMPLE_SERVER_CONTEXT devCtx =
+        GetServerDeviceContext(WdfIoQueueGetDevice(Queue));
+
+    if (Length == 0 || Length > SPLATPLOST_MAX_REPORT_SIZE) {
+        WdfRequestComplete(Request, STATUS_INVALID_BUFFER_SIZE);
+        return;
+    }
+
+    status = WdfRequestRetrieveInputBuffer(Request, Length, &input, NULL);
+    if (!NT_SUCCESS(status)) {
+        WdfRequestComplete(Request, status);
+        return;
+    }
+
+    WdfSpinLockAcquire(devCtx->ConnectionListLock);
+    connectionObject = devCtx->InterruptConnection;
+    if (connectionObject != NULL) {
+        WdfObjectReference(connectionObject);
+    }
+    WdfSpinLockRelease(devCtx->ConnectionListLock);
+
+    if (connectionObject == NULL) {
+        WdfRequestComplete(Request, STATUS_DEVICE_NOT_CONNECTED);
+        return;
+    }
+
+    connection = GetConnectionObjectContext(connectionObject);
+    BthEchoSrvSendEcho(&devCtx->Header, connection, input, Length);
+    WdfObjectDereference(connectionObject);
+    WdfRequestCompleteWithInformation(Request, STATUS_SUCCESS, Length);
+}
+
+VOID
+SplatplostEvtIoDeviceControl(
+    _In_ WDFQUEUE Queue,
+    _In_ WDFREQUEST Request,
+    _In_ size_t OutputBufferLength,
+    _In_ size_t InputBufferLength,
+    _In_ ULONG IoControlCode
+    )
+{
+    NTSTATUS status;
+    PSPLATPLOST_STATUS output = NULL;
+    PBTHECHOSAMPLE_SERVER_CONTEXT devCtx =
+        GetServerDeviceContext(WdfIoQueueGetDevice(Queue));
+
+    UNREFERENCED_PARAMETER(InputBufferLength);
+
+    if (IoControlCode != IOCTL_SPLATPLOST_GET_STATUS) {
+        WdfRequestComplete(Request, STATUS_INVALID_DEVICE_REQUEST);
+        return;
+    }
+
+    if (OutputBufferLength < sizeof(*output)) {
+        WdfRequestComplete(Request, STATUS_BUFFER_TOO_SMALL);
+        return;
+    }
+
+    status = WdfRequestRetrieveOutputBuffer(
+        Request,
+        sizeof(*output),
+        (PVOID *)&output,
+        NULL
+        );
+    if (!NT_SUCCESS(status)) {
+        WdfRequestComplete(Request, status);
+        return;
+    }
+
+    RtlZeroMemory(output, sizeof(*output));
+    WdfSpinLockAcquire(devCtx->ConnectionListLock);
+    if (devCtx->ControlConnection != NULL) {
+        output->ConnectedChannels |= 0x01;
+    }
+    if (devCtx->InterruptConnection != NULL) {
+        output->ConnectedChannels |= 0x02;
+    }
+    output->LocalAddress = devCtx->Header.LocalBthAddr;
+    WdfSpinLockRelease(devCtx->ConnectionListLock);
+
+    WdfRequestCompleteWithInformation(Request, STATUS_SUCCESS, sizeof(*output));
+}
+
+_IRQL_requires_max_(DISPATCH_LEVEL)
+VOID
+SplatplostBridgeConnectionAdded(
+    _In_ PBTHECHOSAMPLE_SERVER_CONTEXT DevCtx,
+    _In_ PBTHECHO_CONNECTION Connection
+    )
+{
+    WDFOBJECT object = WdfObjectContextGetObject(Connection);
+
+    WdfSpinLockAcquire(DevCtx->ConnectionListLock);
+    if (Connection->Psm == SPLATPLOST_CONTROL_PSM) {
+        DevCtx->ControlConnection = object;
+    } else if (Connection->Psm == SPLATPLOST_INTERRUPT_PSM) {
+        DevCtx->InterruptConnection = object;
+    }
+    WdfSpinLockRelease(DevCtx->ConnectionListLock);
+}
+
+_IRQL_requires_max_(DISPATCH_LEVEL)
+VOID
+SplatplostBridgeConnectionRemoved(
+    _In_ PBTHECHOSAMPLE_SERVER_CONTEXT DevCtx,
+    _In_ PBTHECHO_CONNECTION Connection
+    )
+{
+    WDFOBJECT object = WdfObjectContextGetObject(Connection);
+
+    WdfSpinLockAcquire(DevCtx->ConnectionListLock);
+    if (DevCtx->ControlConnection == object) {
+        DevCtx->ControlConnection = NULL;
+    }
+    if (DevCtx->InterruptConnection == object) {
+        DevCtx->InterruptConnection = NULL;
+    }
+    WdfSpinLockRelease(DevCtx->ConnectionListLock);
+}
+
+_IRQL_requires_max_(DISPATCH_LEVEL)
+VOID
+SplatplostBridgePacketReceived(
+    _In_ PBTHECHOSAMPLE_SERVER_CONTEXT DevCtx,
+    _In_ PBTHECHO_CONNECTION Connection,
+    _In_reads_bytes_(BufferLength) PVOID Buffer,
+    _In_ size_t BufferLength
+    )
+{
+    NTSTATUS status;
+    WDFREQUEST request = NULL;
+    PVOID output = NULL;
+    WDFOBJECT object = WdfObjectContextGetObject(Connection);
+
+    if (BufferLength == 0 || BufferLength > SPLATPLOST_MAX_REPORT_SIZE) {
+        return;
+    }
+
+    WdfSpinLockAcquire(DevCtx->ConnectionListLock);
+    if (DevCtx->InterruptConnection != object) {
+        WdfSpinLockRelease(DevCtx->ConnectionListLock);
+        return;
+    }
+    WdfSpinLockRelease(DevCtx->ConnectionListLock);
+
+    status = WdfIoQueueRetrieveNextRequest(DevCtx->PendingReads, &request);
+    if (!NT_SUCCESS(status)) {
+        return;
+    }
+
+    status = WdfRequestRetrieveOutputBuffer(
+        request,
+        BufferLength,
+        &output,
+        NULL
+        );
+    if (!NT_SUCCESS(status)) {
+        WdfRequestComplete(request, status);
+        return;
+    }
+
+    RtlCopyMemory(output, Buffer, BufferLength);
+    WdfRequestCompleteWithInformation(request, STATUS_SUCCESS, BufferLength);
+}
