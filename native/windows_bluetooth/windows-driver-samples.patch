+typedef struct _SPLATPLOST_STATUS {
+    ULONG ConnectedChannels;
+    ULONG Reserved;
+    BTH_ADDR LocalAddress;
+} SPLATPLOST_STATUS, *PSPLATPLOST_STATUS;
+
+NTSTATUS
+SplatplostBridgeInitialize(
+    _In_ WDFDEVICE Device
+    );
+
+_IRQL_requires_max_(DISPATCH_LEVEL)
+VOID
+SplatplostBridgeConnectionAdded(
+    _In_ PBTHECHOSAMPLE_SERVER_CONTEXT DevCtx,
+    _In_ PBTHECHO_CONNECTION Connection
+    );
+
+_IRQL_requires_max_(DISPATCH_LEVEL)
+VOID
+SplatplostBridgeConnectionRemoved(
+    _In_ PBTHECHOSAMPLE_SERVER_CONTEXT DevCtx,
+    _In_ PBTHECHO_CONNECTION Connection
+    );
+
+_IRQL_requires_max_(DISPATCH_LEVEL)
+VOID
+SplatplostBridgePacketReceived(
+    _In_ PBTHECHOSAMPLE_SERVER_CONTEXT DevCtx,
+    _In_ PBTHECHO_CONNECTION Connection,
+    _In_reads_bytes_(BufferLength) PVOID Buffer,
+    _In_ size_t BufferLength
+    );
+
+EVT_WDF_IO_QUEUE_IO_READ SplatplostEvtIoRead;
+EVT_WDF_IO_QUEUE_IO_WRITE SplatplostEvtIoWrite;
+EVT_WDF_IO_QUEUE_IO_DEVICE_CONTROL SplatplostEvtIoDeviceControl;
